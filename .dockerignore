# Build outputs / caches — regenerated inside the image.
.next
.turbo
node_modules
out
dist
coverage

# The BYOT runtime is regenerated by the prebuild step; ship the *-src only.
public/__numu-runtime

# VCS / editor / OS
.git
.github
.vscode
.idea
*.log
.DS_Store

# Local env — never bake secrets into the image. Runtime env comes from
# the compose env_file on the droplet.
.env
.env.local
.env.*.local

# Docs / deploy kit (not needed in the build context)
README.md
docs
deploy
docker-compose*.yml
Dockerfile
.dockerignore
