# =============================================================================
# numu-storefront — prod EC2 SERVER-SIDE runtime env  (copy to deploy/.env.prod)
# =============================================================================
# Pull authoritative values from the current Heroku app so prod behaviour is
# identical:   heroku config -a <your-storefront-app> -s
# Then `chmod 600 deploy/.env.prod`.
#
# NOTE: NEXT_PUBLIC_* are NOT here — they are inlined into the client bundle at
# BUILD time by CI (see .github/workflows/cd-prod.yml build-args). This file is
# only the server-side runtime env the container reads at start.
# =============================================================================

# numu-storefront uses NUMU_API_URL AS-IS and does NOT append the prefix —
# it MUST end in /api/v1.
NUMU_API_URL=https://api.numueg.app/api/v1

# Tenant resolution: host.slice(0, -(PLATFORM_DOMAIN+1)). For <store>.numueg.app
# the tenant is the leftmost label, so this is the bare apex.
NUMU_PLATFORM_DOMAIN=numueg.app

# Hosts allowed for next/image optimization (comma-separated). Copy from Heroku.
NUMU_IMAGE_HOSTS=

# Shared secret for on-demand ISR revalidation. Copy from Heroku (must match
# whatever the API/webhook uses to trigger revalidation).
REVALIDATION_SECRET=
