{
  "name": "numu-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next dev -p 3100",
    "dev:turbopack": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next dev --turbopack -p 3100",
    "predev": "node scripts/build-runtime.mjs",
    "prebuild": "node scripts/build-runtime.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 next build",
    "build:runtime": "node scripts/build-runtime.mjs",
    "prestart": "node scripts/build-runtime.mjs",
    "start": "next start -p 3100",
    "lint": "next lint",
    "clean": "rimraf .next .turbo node_modules/.cache public/__numu-runtime"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@numueg/theme-sdk": "^0.3.1",
    "next": "^16.2.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.12",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "next": {
      "postcss": ">=8.5.10"
    }
  }
}
